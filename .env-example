# URL de conexión a la base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/nombre_bd"

# Entorno de ejecución (development, production)
NODE_ENV="development"

# Puerto en el que corre el servidor backend (por defecto 4000 si no se define)
PORT=4000

# Secreto para firmar los JSON Web Tokens (JWT)
JWT_SECRET="tu_secreto_super_seguro"

# API Key de Gemini para el chatbot de asistencia
GEMINI_API_KEY="tu_api_key_de_gemini"

# Orígenes permitidos para CORS (URL del frontend)
CORS_ORIGIN="http://localhost:5173"
